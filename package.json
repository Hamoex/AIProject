{
  "name": "ai-elite",
  "version": "1.2.3",
  "description": "AI ELITE is not another chatbot you type at. It is an intelligent Voice-First Operating Layer that gives you complete, hands-free authority over your digital environment. It lives on your desktop, watches your workflow, and executes your intent instantly.",
  "main": "./out/main/index.js",
  "author": "Hamoex",
  "homepage": "(Soon)",
  "scripts": {
    "build": "npx electron-builder --win"
  },
  "build": {
    "appId": "com.hamoex.aleliteh",
    "productName": "Ai Elite H",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Hamoex",
      "repo": "AIProject"
    },
    "extraResources": [
      {
        "from": "resources/app-update.yml",
        "to": "app-update.yml"
      }
    ],
    "files": [
      "out/**/*",
      "resources/**/*",
      "assets/**/*",
      "models/**/*",
      "eng.traineddata",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "include": "build/customInstall.nsh"
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@google-cloud/local-auth": "^3.0.1",
    "@google/genai": "^1.50.1",
    "@gsap/react": "^2.1.2",
    "@huggingface/inference": "^4.13.15",
    "@monaco-editor/react": "^4.7.0",
    "@notionhq/client": "^5.18.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tavily/core": "^0.7.2",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "bytenode": "^1.5.7",
    "cheerio": "^1.2.0",
    "clipboardy": "^5.3.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "face-api.js": "^0.22.2",
    "framer-motion": "^12.38.0",
    "glob": "^13.0.6",
    "googleapis": "^171.4.0",
    "groq-sdk": "^1.1.2",
    "gsap": "^3.15.0",
    "ignore": "^7.0.5",
    "immer": "^11.1.4",
    "leaflet": "^1.9.4",
    "loudness": "^0.4.2",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "node-window-manager": "^2.2.4",
    "pdf-parse": "^2.4.5",
    "prismjs": "^1.30.0",
    "puppeteer": "^24.41.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode.react": "^4.2.0",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "react-tooltip": "^5.30.1",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "screenshot-desktop": "^1.15.3",
    "tesseract.js": "^7.0.0",
    "three": "^0.184.0",
    "untun": "^0.1.3",
    "vectordb": "^0.21.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "asarmor": "^3.0.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
